{
	"name": "vault-full-statistics",
	"version": "1.20.2",
	"description": "Vault statistics in the status bar plus a dedicated view with own/source ratio and a 30-day sparkline of how your knowledge base evolves.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "jest --config jest.config.js",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"statistics",
		"vault",
		"metrics",
		"knowledge-management"
	],
	"author": "Mikhail Savin <jtprogru@gmail.com>",
	"readme": "README.md",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jtprogru/obsidian-vault-full-statistics-plugin.git"
	},
	"homepage": "https://github.com/jtprogru/obsidian-vault-full-statistics-plugin#readme",
	"bugs": {
		"url": "https://github.com/jtprogru/obsidian-vault-full-statistics-plugin/issues"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^26.0.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.6.0",
		"globals": "^17.7.0",
		"jest": "^30.4.2",
		"obsidian": "1.13.1",
		"ts-jest": "^29.4.11",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0"
	}
}
